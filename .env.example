# 複製成 .env 後填入，所有值都不要 commit
# ── Bitfinex（沒填 = 自動進入 DRY_RUN 模擬模式）─────────────
# 權限只需要：Account Info(讀) + Margin Funding(讀寫) + Wallets(讀)，不要開提幣！
BFX_API_KEY=
BFX_API_SECRET=

# ── 模式 ──────────────────────────────────────────────
# true = 完整跑策略但不真正下單（本機測試用）
DRY_RUN=true

# ── Telegram（@BotFather 建 bot 拿 token；chat id 可問 @userinfobot）──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Supabase（沒填 = 不寫 DB，純本機跑也 OK）────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
